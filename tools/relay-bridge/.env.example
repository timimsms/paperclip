# Required — Paperclip instance
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=your-paperclip-api-key-here
PAPERCLIP_COMPANY_ID=your-company-uuid-here

# Required — sms-sushi (from ~/.claude/settings.json mcpServers.sms-sushi.env)
SMS_SUSHI_API_TOKEN=sms_...
SMS_SUSHI_BASE_URL=https://sms-sushi.fly.dev

# Optional tuning
POLL_INTERVAL_MS=15000
SMS_POLL_TIMEOUT_MS=29000
